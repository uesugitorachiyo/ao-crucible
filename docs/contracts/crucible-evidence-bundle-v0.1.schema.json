{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao-foundry.dev/schemas/crucible-evidence-bundle-v0.1.schema.json",
  "type": "object",
  "required": ["schema_version", "bundle_id", "artifacts"],
  "properties": {
    "schema_version": { "const": "ao.crucible.evidence-bundle.v0.1" },
    "bundle_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role", "schema_version", "sha256", "redacted"],
        "properties": {
          "path": { "type": "string" },
          "role": { "type": "string" },
          "schema_version": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "redacted": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
